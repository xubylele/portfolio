---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from "@vercel/speed-insights/astro";
import LanguageIndicator from '../../components/ui/LanguageIndicator.astro';
import PageTransition from '../../components/ui/PageTransition.astro';
import { useTranslations } from '../../i18n/utils';
import '../../styles/animations.css';
import '../../styles/global.css';

const t = useTranslations('en');
const site = 'https://dev.xuby.cl';
const canonical = new URL(Astro.url.pathname, site).href;
const title = 'Fullstack Developer | Freelancer in Chile | Xavier Díaz';
const description = 'Xuby is a fullstack developer with +5 years of experience. Available for freelance projects and custom software development.';
const ogImage = `${site}/logo.png`;
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${site}/#person`,
  name: 'Xavier Díaz',
  alternateName: 'Xuby',
  url: site,
  jobTitle: 'Fullstack Developer',
  image: `${site}/logo.png`,
  sameAs: ['https://github.com/xubylele', 'https://www.linkedin.com/in/xubylele/'],
  knowsAbout: ['TypeScript', 'JavaScript', 'Python', 'React', 'Astro', 'Node.js', 'PostgreSQL'],
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Xuby - Fullstack Developer',
  url: site,
  publisher: { '@id': `${site}/#person` },
  inLanguage: ['en', 'es'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#4b1e3d" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en" />
    <meta property="og:site_name" content="Xuby" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <link rel="alternate" hreflang="x-default" href="https://dev.xuby.cl/es/" />
    <link rel="alternate" hreflang="en" href="https://dev.xuby.cl/en/" />
    <link rel="alternate" hreflang="es" href="https://dev.xuby.cl/es/" />
    <Analytics />
    <SpeedInsights />
  </head>
  <body>
    <PageTransition />
    <LanguageIndicator />
    <slot />
    
    <script>
      (function(l) {
        if (l.search[1] === '/' ) {
          var decoded = l.search.slice(1).split('&').map(function(s) { 
            return s.replace(/~and~/g, '&')
          }).join('?');
          window.history.replaceState(null, null,
              l.pathname.slice(0, -1) + decoded + l.hash
          );
        }
      }(window.location))
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    overscroll-behavior: none;
  }
</style>
